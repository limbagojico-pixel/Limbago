@page "/"

<PageTitle>Home</PageTitle>

<h1 class="title">JUST FOR YOU!</h1>

<div class="quotes-container">

    @foreach (var quote in quotes)
    {
        <div class="quote-card">
            <p>"@quote.Text"</p>

            <div class="actions">
                <button class="agree" @onclick="() => Vote(quote, true)">Agree</button>
                <button class="disagree" @onclick="() => Vote(quote, false)">Disagree</button>
            </div>

            <div class="result">
                👍 @quote.AgreeCount | 👎 @quote.DisagreeCount
            </div>
        </div>
    }

</div>

@code {
    public class Quote
    {
        public string Text { get; set; }
        public int AgreeCount { get; set; } = 0;
        public int DisagreeCount { get; set; } = 0;
    }

    List<Quote> quotes = new List<Quote>
    {
        new Quote { Text = "Keep going, even when it's hard." },
        new Quote { Text = "Small steps every day lead to big results." },
        new Quote { Text = "You are stronger than you think." },
        new Quote { Text = "Discipline is the key to success." },
        new Quote { Text = "Dream it. Work for it. Achieve it." },
        new Quote { Text = "Don’t quit. You’re closer than you think." },
        new Quote { Text = "Success starts with self-belief." },
        new Quote { Text = "Hard work beats talent when talent doesn’t work hard." },
        new Quote { Text = "Stay focused and never give up." },
        new Quote { Text = "Your only limit is your mind." },
        new Quote { Text = "Make today count." },
        new Quote { Text = "Progress, not perfection." },
        new Quote { Text = "Turn your dreams into plans." },
        new Quote { Text = "Be better than yesterday." },
        new Quote { Text = "Success is built daily." }
    };

    void Vote(Quote quote, bool isAgree)
    {
        if (isAgree)
            quote.AgreeCount++;
        else
            quote.DisagreeCount++;
    }
}