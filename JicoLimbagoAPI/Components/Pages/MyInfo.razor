@page "/myinfo"

<div class="portfolio-container">

    <!-- About Me Card -->
    <div class="card led-border hover-glow about-me-card">
        <img src="images/jics.jpg" alt="My Photo" class="profile-photo" />
        <h2>ABOUT ME</h2>
        <p>Hi! I'm Jico Limbago, an enthusiastic learner who is passionate about growing my skills and becoming successful in the future. I’m eager to explore and understand more about the tech field, especially web development and programming. When I’m not coding, I enjoy playing mobile games—they keep me creative and help me think strategically.</p>
    </div>

   <!-- Skills Card -->
<div class="card led-border hover-glow skills-card">
    <h2>SKILLS I WANT TO IMPROVE:</h2>

    <div class="skills-vertical">
        <div class="skill-item">
            <div class="skill-circle">
                <img src="images/c.jpg" alt="C#">
            </div>
            <span>C#</span>
        </div>

        <div class="skill-item">
            <div class="skill-circle">
                <img src="images/blazor.webp" alt="Blazor">
            </div>
            <span>Blazor</span>
        </div>

        <div class="skill-item">
            <div class="skill-circle">
                <img src="images/html.jpg" alt="HTML/CSS">
            </div>
            <span>HTML/CSS</span>
        </div>

        <div class="skill-item">
            <div class="skill-circle">
                <img src="images/js.png" alt="JavaScript">
            </div>
            <span>JavaScript</span>
        </div>

        <div class="skill-item">
            <div class="skill-circle">
                <img src="images/sql.png" alt="SQL">
            </div>
            <span>SQL</span>
        </div>
    </div>
</div>

    <!-- Projects Card -->
    <div class="card led-border hover-glow projects-card">
        <h2>PROJECTS</h2>
        <div class="project-card">
            <img src="images/project.png" alt="Project 1" />
            <div class="project-info">
                <h3>My Portfolio Website</h3>
                <p>A responsive Blazor portfolio showcasing my skills and projects.</p>
                <a href="#" target="_blank">View Project</a>
            </div>
        </div>
        </div>
    </div>


